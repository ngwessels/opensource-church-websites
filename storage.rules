rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Prefer auth custom claims (set server-side on login) — works without
    // cross-service Firestore lookups in Storage rules.
    function isAdminFromClaim() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isAdminFromFirestore() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isAdmin() {
      return isAdminFromClaim() || isAdminFromFirestore();
    }

    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /form-uploads/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
