rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function isFinance() {
      return isSignedIn() && userDoc().data.role == 'finance';
    }

    function canManageDonations() {
      return isAdmin() || isFinance();
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /users/{uid}/mcpConnections/{connectionId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /site/{docId} {
      allow read, write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read, write: if isAdmin();
    }

    match /navNodes/{nodeId} {
      allow read, write: if isAdmin();
    }

    match /media/{mediaId} {
      allow read, write: if isAdmin();
    }

    match /mediaFolders/{folderId} {
      allow read, write: if isAdmin();
    }

    match /bulletins/{bulletinId} {
      allow read, write: if isAdmin();
    }

    match /formSubmissions/{submissionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /donations/{donationId} {
      allow read: if canManageDonations();
      allow write: if false;
    }

    match /mcpOAuthClients/{clientId} {
      allow read, write: if false;
    }

    match /mcpOAuthCodes/{codeId} {
      allow read, write: if false;
    }

    match /mcpTokenLookup/{tokenHash} {
      allow read, write: if false;
    }

    match /analyticsEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /auditEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;

      match /snapshots/{snapshotId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }
    }
  }
}
